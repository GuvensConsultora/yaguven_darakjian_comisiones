<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Refresca el mes en curso y el anterior: fija tramos y hace entrar los cobros. -->
    <record id="ir_cron_commission_recompute" model="ir.cron">
        <field name="name">Comisiones: recálculo mensual</field>
        <field name="model_id" ref="model_yaguven_commission_target"/>
        <field name="state">code</field>
        <field name="code">model._cron_recompute()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall">2026-07-09 03:00:00</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
